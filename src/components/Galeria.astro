---
const proyectos = [
  { keyTitle: 'g1_title', keyTag: 'g_tag_residencial', title: 'Remodelación de Cocina', tag: 'Residencial', img: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80' },
  { keyTitle: 'g2_title', keyTag: 'g_tag_interiores', title: 'Diseño de Sala Principal', tag: 'Interiores', img: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=600&q=80' },
  { keyTitle: 'g3_title', keyTag: 'g_tag_comercial', title: 'Oficina Comercial', tag: 'Comercial', img: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80' },
  { keyTitle: 'g4_title', keyTag: 'g_tag_residencial', title: 'Baño de Lujo', tag: 'Residencial', img: 'https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=600&q=80' },
  { keyTitle: 'g5_title', keyTag: 'g_tag_exterior', title: 'Terraza Exterior', tag: 'Exterior', img: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=80' },
  { keyTitle: 'g6_title', keyTag: 'g_tag_residencial', title: 'Renovación Total', tag: 'Residencial', img: 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=600&q=80' },
];
---

<section class="galeria" id="galeria">
  <div class="container">
    <div class="section-divider"></div>
    <h2 class="section-title" data-i18n="galeria_title">Nuestros Proyectos</h2>
    <p class="section-subtitle" data-i18n="galeria_subtitle">
      Cada proyecto cuenta una historia. Descubre cómo transformamos ideas en espacios reales.
    </p>
    <div class="galeria-grid">
      {proyectos.map((p) => (
        <div class="proyecto-card">
          <div class="proyecto-img">
            <img src={p.img} alt={p.keyTitle} class="proyecto-foto" loading="lazy" />
          </div>
          <div class="proyecto-info">
            <span class="proyecto-tag" data-i18n={p.keyTag}>{p.tag}</span>
            <h3 class="proyecto-title" data-i18n={p.keyTitle}>{p.title}</h3>
          </div>
        </div>
      ))}
    </div>
    <div class="galeria-cta">
      <a href="#contacto" class="btn-outline" data-i18n="galeria_cta">Solicita una cotización</a>
    </div>
  </div>
</section>

<style>
  .galeria {
    padding: var(--section-padding);
    background: var(--bg-secondary);
  }

  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .proyecto-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all var(--transition);
    background: var(--bg-card);
  }

  .proyecto-card:hover {
    border-color: var(--gold);
    transform: translateY(-4px);
  }

  .proyecto-card:hover .proyecto-img {
    transform: scale(1.02);
  }

  .proyecto-img {
    aspect-ratio: 4/3;
    overflow: hidden;
    transition: transform 0.4s ease;
  }

  .proyecto-foto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .proyecto-card:hover .proyecto-foto {
    transform: scale(1.08);
  }

  .proyecto-info {
    padding: 20px;
  }

  .proyecto-tag {
    display: inline-block;
    padding: 4px 12px;
    font-size: 0.75rem;
    color: var(--gold);
    background: rgba(201, 168, 76, 0.1);
    border-radius: 50px;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .proyecto-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .galeria-cta {
    text-align: center;
    margin-top: 50px;
  }

  @media (max-width: 1024px) {
    .galeria-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .galeria-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
